{
  "expo": {
    "name": "riddle-realm",
    "entryPoint": "./index.js",
    "slug": "riddle-realm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/riddles-logo.png",
    "scheme": "riddlerealm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/riddles-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sai_rohit.riddlerealm",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/riddles-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-1254844707253302~8049954364",
    "ios_app_id": "ca-app-pub-3940256099942544~1458002511"
  }
}